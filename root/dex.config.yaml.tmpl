# Dex configuration template.
# Rendered by scripts/self-check/ensure-dex.sh to
#   /DATA/AppData/yundera/dex/config.yaml
# on every self-check. DO NOT edit the rendered file — edit this template and
# let the self-check re-render it. Substituted tokens: ${DOMAIN}, ${BRIDGE_SECRET}
# (CasaOS connector), and ${AUTHELIA_DEX_SECRET} (Local Account connector).

issuer: https://auth-${DOMAIN}

# Single SQLite file living in the mounted data dir (/data -> host
# /DATA/AppData/yundera/dex). Dex creates + migrates it on first start; it must
# be writable by the dex container uid (1001) — ensure-dex.sh owns the perms.
storage:
  type: sqlite3
  config:
    file: /data/dex.db

# Caddy terminates TLS at auth-${DOMAIN} and reverse-proxies to this HTTP port.
web:
  http: 0.0.0.0:5556

# Client-management gRPC API. auth-registrar (mesh-auth, REGISTRAR_BACKEND=dex)
# calls CreateClient here when a PCS app first logs in. This API is
# UNAUTHENTICATED, so it is bound to the isolated `dex-internal` network's static
# IP ONLY (not 0.0.0.0). App containers live on `pcs` and therefore cannot reach
# it; only auth-registrar (also on dex-internal) can. The IP is pinned in
# docker-compose.yml — keep the two in sync.
grpc:
  addr: 172.31.7.2:5557

# Custom login UI. `dir` MUST be set to the on-disk web dir — without it Dex
# serves its embedded (in-binary) assets and ignores files on disk, so the
# bind-mounts have no effect. /srv/dex/web is the image's complete stock web
# tree (templates + static + themes/{light,dark}); docker-compose.yml overlays
# our login.html/header.html and themes/yundera onto it, and ensure-dex.sh
# provisions those from the template's dex-theme/.
#
# `issuer` is the display name in the "Log in to <issuer>" heading and <title>
# — deliberately the PCS's own domain, not a Yundera product name. The PCS
# belongs to its owner, and this template is shared with the nsl.sh FOSS
# branch, so the login page stays vendor-neutral. It doubles as the anti-
# phishing cue: it tells you which PCS you are handing credentials to.
frontend:
  dir: /srv/dex/web
  theme: yundera
  issuer: ${DOMAIN}

oauth2:
  # Every PCS app is first-party; skip the per-app consent screen.
  skipApprovalScreen: true

# No local password DB. Dex is a pure broker — the local account lives in
# Authelia (the "Local Account" connector below). The old enablePasswordDB
# break-glass admin was removed once Authelia became the self-contained local
# login (it has its own reset + rate limiting and does not depend on CasaOS).

# Application clients are NOT defined statically — auth-registrar registers them
# dynamically over Dex's gRPC API. The registrar is stateless (it persists no
# secrets), and apps re-register on every login, so the client list here is
# disposable cache that rebuilds itself.

connectors:
  # Local Account — Authelia, the PCS-local credential store (replaces reliance
  # on CasaOS). Publicly-trusted host so Dex's back-channel TLS validates against
  # system roots. Authelia's own login page carries the password-reset link.
  - type: oidc
    id: authelia
    name: Local Account
    config:
      issuer: https://local-auth-${DOMAIN}
      clientID: dex
      clientSecret: "${AUTHELIA_DEX_SECRET}"
      # Dex's own connector callback.
      redirectURI: https://auth-${DOMAIN}/callback
      # Authelia 4.39 returns scope claims (preferred_username, email, name) from
      # its userinfo endpoint rather than in the ID token, so Dex must fetch it.
      getUserInfo: true
      userNameKey: preferred_username
      scopes:
        - openid
        - profile
        - email

  - type: oidc
    id: casaos
    name: CasaOS
    config:
      # The casaos-oidc-bridge. Must be a publicly-trusted host so Dex's
      # back-channel TLS to it validates against system roots.
      issuer: https://casaos-oidc-${DOMAIN}
      clientID: dex
      clientSecret: "${BRIDGE_SECRET}"
      # Dex's own connector callback.
      redirectURI: https://auth-${DOMAIN}/callback
      userNameKey: name
      scopes:
        - openid
        - profile
        - email
